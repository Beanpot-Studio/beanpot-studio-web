---
import LogoPanel from "./LogoPanel.astro";
---

<section
  class="hero-section relative overflow-hidden border-b border-primary-200/50"
  aria-labelledby="hero-heading"
>
  <div
    class="container-custom relative z-10 py-12 sm:py-14 md:py-16 lg:py-20"
  >
    <div
      class="grid grid-cols-1 items-start gap-10 sm:gap-11 lg:grid-cols-12 lg:gap-10"
    >
      <div
        class="space-y-4 sm:space-y-5 lg:col-span-6 xl:col-span-7 lg:pt-10 max-w-2xl"
      >
        <span class="pill-marketing">
          Friendly software for real families
        </span>

        <h1
          id="hero-heading"
          class="font-display text-display-1 font-semibold leading-[1.08] text-primary-900 max-w-[20ch]"
        >
          <span class="text-primary-800">Practical apps</span>, made with care,
          for real life
        </h1>

        <p
          class="font-sans text-base sm:text-lg text-primary-800 max-w-[52ch] leading-relaxed"
        >
          We are a small Boston studio: the kind of place where your kids&apos;
          practice schedule and a landlord&apos;s workflow both get the same
          thoughtfulness. Today that means <strong
            class="font-semibold text-primary-900">helping kids build habits</strong
          > at home, and
          <strong class="font-semibold text-primary-900"
            >practical, AI-assisted tools</strong
          > for rental work—clarity, not more spreadsheets.
        </p>

        <div
          class="flex flex-col sm:flex-row sm:items-center gap-4 pt-1 sm:pt-0.5"
        >
          <a
            href="#featured-project-showcase"
            class="btn-primary w-full sm:w-auto justify-center"
          >
            See what we&apos;re building
          </a>
          <a
            href="/contact"
            class="btn-secondary w-full sm:w-auto justify-center"
          >
            Get in touch
          </a>
        </div>
      </div>

      <div
        class="relative flex justify-center items-start lg:col-span-6 xl:col-span-5"
      >
        <LogoPanel />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(
      165deg,
      #ebe6dc 0%,
      #f6f2eb 45%,
      #f0ebe2 100%
    );
  }

  .hero-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle at 1px 1px,
      rgba(100, 84, 63, 0.12) 1px,
      transparent 0
    );
    background-size: 40px 40px;
    opacity: 0.5;
    pointer-events: none;
  }

</style>
