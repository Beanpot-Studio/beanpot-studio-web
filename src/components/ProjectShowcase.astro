---
import { Image } from "astro:assets";
import differentestLogo from "../assets/grayscale-differentest-logo.png";
import practiceBuddyLogo from "../assets/grayscale-practicebuddy-logo.png";

const differentestProjects = [
  {
    title: "DifferenTest for Teachers",
    description:
      "Build lesson plans, generate assessments, and assess student progress.",
    image: "/teacher-experience.mp4",
    category: "Teachers",
  },
  {
    title: "DifferenTest for Students",
    description:
      "Take assessments, leverage assistive technology, and earn badges and certificates.",
    image: "/student-experience.mp4",
    category: "Students",
  },
  {
    title: "DifferenTest Premium",
    description:
      "For the premium subscriber, we offer enhanced features including credential design, curriculum development, and reports.",
    image: "/premium-experience.mp4",
    category: "Premium",
  },
];

const practiceBuddyProjects = [
  {
    title: "Coaching practice, simply",
    description:
      "Set up practice routines, see progress, and help kids stay on track—without turning every day into a battle of wills.",
    image: "/pb-teachers.mp4",
    category: "Educators & parents",
  },
  {
    title: "Skills through repetition",
    description:
      "Short, focused sessions that reward consistency so kids build confidence in math, reading, and more at their own pace.",
    image: "/pb-students.mp4",
    category: "Kids",
  },
];
---

<section
  id="featured-project-showcase"
  class="scroll-mt-[4.5rem] border-t border-primary-200/50 bg-primary-50/90"
>
  <div class="section-padding container-custom">
    <header
      class="mb-12 flex max-w-4xl flex-col gap-4 sm:mb-16 md:flex-row md:items-end md:justify-between"
    >
      <div>
        <p class="kicker">What we build</p>
        <h2
          class="font-display mt-1 text-display-2 font-semibold text-primary-950"
        >
          <span class="text-primary-800">Products</span>
        </h2>
      </div>
    </header>

    <!-- DifferenTest Section -->
    <div
      class="mx-auto mb-16 w-full max-w-4xl rounded-2xl border border-primary-200/60 bg-white/90 p-6 shadow-sm sm:p-10 md:mb-20 md:p-12 lg:p-16"
    >
      <div class="mb-8 flex flex-col items-center text-center sm:mb-10">
        <Image
          src={differentestLogo}
          alt="DifferenTest"
          class="mb-5 h-16 w-auto sm:h-20"
        />
        <p
          class="max-w-prose text-balance text-lg leading-[1.625] text-primary-800 [word-spacing:0.02em]"
        >
          <span class="font-semibold text-primary-900">DifferenTest</span> is a platform
          for teachers to create and share a fully automated but customizable assessment
          and credentialing experience with their students.
        </p>
      </div>

      <div class="grid w-full grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-8">
        {
          differentestProjects.map((project) => (
            <article class="group flex min-w-0 w-full flex-col overflow-hidden rounded-2xl border border-primary-200/50 bg-primary-50/30 shadow-sm">
              <div class="aspect-video overflow-hidden">
                {project.image.endsWith(".mp4") ? (
                  <video
                    class="js-showcase-video h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.02]"
                    loop
                    muted
                    playsinline
                  >
                    <source src={project.image} type="video/mp4" />
                    Your browser does not support the video tag.
                  </video>
                ) : (
                  <img
                    src={project.image}
                    alt={project.title}
                    class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.02]"
                  />
                )}
              </div>
              <div class="space-y-2 p-5 sm:p-6">
                <span class="tag-sage">{project.category}</span>
                <h3 class="font-display text-xl font-semibold text-primary-950">
                  {project.title}
                </h3>
                <p class="text-base leading-relaxed text-primary-800">
                  {project.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
      <div class="pt-2 text-center">
        <a
          href="https://differentest.netlify.app"
          class="btn-secondary inline-flex"
          target="_blank"
          rel="noopener noreferrer"
        >
          Visit DifferenTest
        </a>
      </div>
    </div>

    <!-- Practice Buddy Section -->
    <div
      class="mx-auto w-full max-w-4xl rounded-2xl border border-primary-200/60 bg-white/90 p-6 shadow-sm sm:p-10 md:p-12 lg:p-16"
    >
      <div class="mb-8 flex flex-col items-center text-center sm:mb-10">
        <Image
          src={practiceBuddyLogo}
          alt="Practice Buddy"
          class="mb-5 h-16 w-auto sm:h-20"
        />
        <p
          class="max-w-prose text-balance text-lg leading-[1.625] text-primary-800 [word-spacing:0.02em]"
        >
          <span class="font-semibold text-primary-900">Practice Buddy</span> helps
          you make kids' practice a normal part of the day: structured sessions, clear
          feedback, and a gentler way to build skills that last.
        </p>
      </div>

      <div class="grid w-full grid-cols-1 gap-8 sm:grid-cols-2 sm:gap-8">
        {
          practiceBuddyProjects.map((project) => (
            <article class="group flex min-w-0 w-full flex-col overflow-hidden rounded-2xl border border-primary-200/50 bg-primary-50/30 shadow-sm">
              <div class="aspect-video overflow-hidden">
                {project.image.endsWith(".mp4") ? (
                  <video
                    class="js-showcase-video h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.02]"
                    loop
                    muted
                    playsinline
                  >
                    <source src={project.image} type="video/mp4" />
                    Your browser does not support the video tag.
                  </video>
                ) : (
                  <img
                    src={project.image}
                    alt={project.title}
                    class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.02]"
                  />
                )}
              </div>
              <div class="space-y-2 p-5 sm:p-6">
                <span class="tag-sage">{project.category}</span>
                <h3 class="font-display text-xl font-semibold text-primary-950">
                  {project.title}
                </h3>
                <p class="text-base leading-relaxed text-primary-800">
                  {project.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
      <div class="pt-2 text-center">
        <a
          href="https://practicebuddyapp.netlify.app"
          class="btn-secondary inline-flex"
          target="_blank"
          rel="noopener noreferrer"
        >
          Visit Practice Buddy
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  function initShowcaseVideos() {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (reduceMotion) return;
    for (const el of document.querySelectorAll("video.js-showcase-video")) {
      if (!(el instanceof HTMLVideoElement)) continue;
      el.muted = true;
      void el.play().catch(() => {});
    }
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initShowcaseVideos, {
      once: true,
    });
  } else {
    initShowcaseVideos();
  }
</script>
