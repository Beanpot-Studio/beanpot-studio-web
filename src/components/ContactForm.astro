---
import LogoPanel from "./LogoPanel.astro";

const fieldClass =
  "w-full rounded-xl border-2 border-primary-200 bg-primary-50/40 px-4 py-3 font-sans text-primary-900 placeholder:text-primary-500/50 " +
  "focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/25";
---

<section
  class="scroll-mt-[4.5rem] border-t border-primary-200/50 bg-primary-50/90"
  aria-labelledby="contact-title"
>
  <div class="section-padding container-custom">
    <header
      class="mb-10 max-w-3xl sm:mb-12"
    >
      <p class="kicker">Get in touch</p>
      <h1
        id="contact-title"
        class="font-display mt-2 text-display-1 font-semibold text-primary-950"
      >
        Contact
      </h1>
      <p
        class="mt-4 max-w-prose font-sans text-base leading-relaxed text-primary-800 sm:text-lg"
      >
        Have a question about Practice Buddy, partnerships, or other work
        in progress? We read every message and reply to serious inquiries.
      </p>
    </header>

    <div
      class="grid grid-cols-1 items-start gap-10 lg:grid-cols-12 lg:gap-12"
    >
      <div class="min-w-0 lg:col-span-7">
        <div
          class="rounded-2xl border border-primary-200/40 bg-white/90 p-6 ring-1 ring-primary-200/20 shadow-craft sm:p-8"
        >
          <form
            name="feedback-form"
            method="POST"
            action="/success/"
            class="flex flex-col gap-5"
            aria-describedby="form-description"
            novalidate
            data-netlify="true"
            data-netlify-honeypot="bot-field"
          >
            <p
              id="form-description"
              class="m-0 font-sans text-sm text-primary-800/95"
            >
              All fields marked with an asterisk (*) are required.
            </p>

            <input type="hidden" name="form-name" value="feedback-form" />
            <div hidden aria-hidden="true">
              <label>
                Don't fill this out if you're human: <input
                  name="bot-field"
                  tabindex="-1"
                />
              </label>
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="name"
                class="font-sans text-sm font-semibold text-primary-900"
              >
                Name <span aria-label="required">*</span>
              </label>
              <input
                id="name"
                type="text"
                name="name"
                required
                aria-required="true"
                aria-describedby="name-error"
                class={fieldClass}
              />
              <div id="name-error" class="text-error hidden" role="alert">
                Please enter your name
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="email"
                class="font-sans text-sm font-semibold text-primary-900"
              >
                Email <span aria-label="required">*</span>
              </label>
              <input
                id="email"
                type="email"
                name="email"
                required
                aria-required="true"
                aria-describedby="email-error"
                autocomplete="email"
                class={fieldClass}
              />
              <div id="email-error" class="text-error hidden" role="alert">
                Please enter a valid email address
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label
                for="feedback"
                class="font-sans text-sm font-semibold text-primary-900"
              >
                Message <span aria-label="required">*</span>
              </label>
              <textarea
                id="feedback"
                name="feedback"
                required
                aria-required="true"
                aria-describedby="message-error"
                class={`${fieldClass} min-h-[10rem] resize-y`}
              ></textarea>
              <div id="message-error" class="text-error hidden" role="alert">
                Please enter your message
              </div>
            </div>

            <div class="pt-1">
              <button
                type="submit"
                class="btn-primary px-8"
                aria-label="Submit contact form"
              >
                Send message
              </button>
            </div>
          </form>
        </div>
      </div>

      <div
        class="mx-auto flex w-full max-w-xs justify-center lg:col-span-5 lg:max-w-none"
      >
        <LogoPanel alt="Beanpot Studio" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector("form");
  const inputs = form?.querySelectorAll("input[required], textarea[required]");
  const messageTextarea = form?.querySelector(
    "#feedback"
  ) as HTMLTextAreaElement;
  // Function to validate form
  const validateForm = (event: Event) => {
    event.preventDefault();
    let isValid = true;

    // Check message textarea specifically
    if (messageTextarea && !messageTextarea.value.trim()) {
      isValid = false;
      messageTextarea.setAttribute("aria-invalid", "true");
      document.getElementById("message-error")?.classList.remove("hidden");
    }

    // Check other required inputs
    inputs?.forEach((inputEl) => {
      const input = inputEl as HTMLInputElement | HTMLTextAreaElement;
      const errorDiv = document.getElementById(`${input.id}-error`);

      if (!input.value.trim()) {
        isValid = false;
        input.setAttribute("aria-invalid", "true");
        errorDiv?.classList.remove("hidden");
      } else {
        input.setAttribute("aria-invalid", "false");
        errorDiv?.classList.add("hidden");
      }

      // Email validation - Check if it's an HTMLInputElement before accessing type
      if (
        input instanceof HTMLInputElement &&
        input.type === "email" &&
        input.value
      ) {
        const emailRegex = /^[\s\S]+@[\s\S]+\.[\s\S]+$/; // Changed to a more general regex pattern for emails
        if (!emailRegex.test(input.value)) {
          isValid = false;
          input.setAttribute("aria-invalid", "true");
          errorDiv?.classList.remove("hidden");
        }
      }
    });

    if (isValid) {
      form?.submit();
    }
  };

  // Event listeners
  form?.addEventListener("submit", validateForm);

  inputs?.forEach((inputEl) => {
    const input = inputEl as HTMLInputElement | HTMLTextAreaElement;
    input.addEventListener("input", () => {
      const errorDiv = document.getElementById(`${input.id}-error`);
      input.setAttribute("aria-invalid", "false");
      errorDiv?.classList.add("hidden");
    });
  });
</script>

<style>
  .text-error {
    @apply text-error-600 text-sm mt-0.5;
  }
</style>
