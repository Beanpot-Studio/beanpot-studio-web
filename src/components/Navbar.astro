<header
  class="sticky top-0 w-full z-50 border-b border-primary-200/40 shadow-sm backdrop-blur-md"
  style="background-image: linear-gradient(180deg, rgba(250, 248, 244, 0.97) 0%, rgba(240, 237, 230, 0.95) 100%), url('/beans.jpg'); background-size: cover; background-position: center center;"
>
  <div class="container-custom py-4">
    <nav class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        <div
          class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-full bg-primary-100 shadow-craft-sm ring-1 ring-inset ring-primary-300/50"
        >
          <span class="text-xl leading-none" aria-hidden="true">🫘</span>
        </div>
        <div class="flex flex-col">
          <span class="font-display text-lg font-semibold leading-tight text-primary-900"
            >Beanpot Studio</span
          >
       
        </div>
      </a>

      {/* New wrapper for Desktop Nav and CTA to push them to the right */}
      <div class="hidden md:flex items-center">
        {/* Desktop Navigation Links */}
        <div class="flex items-center space-x-8">
          <a
            href="/about"
            class="inline-flex min-h-11 items-center rounded-lg px-1.5 py-1.5 -mx-1.5 font-medium text-primary-800 transition-colors hover:text-secondary-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-sage-500/50"
            >About Us</a
          >
          <a
            href="/#shared-values"
            class="inline-flex min-h-11 items-center rounded-lg px-1.5 py-1.5 -mx-1.5 font-medium text-primary-800 transition-colors hover:text-secondary-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-sage-500/50"
            >How we work</a
          >
          <a
            href="/#featured-project-showcase"
            class="inline-flex min-h-11 items-center rounded-lg px-1.5 py-1.5 -mx-1.5 font-medium text-primary-800 transition-colors hover:text-secondary-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-sage-500/50"
            >Projects</a
          >
        </div>

        {/* CTA Button */}
        <div class="ml-8">
          <a href="/contact" class="btn-primary">Contact Us</a>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        id="menu-toggle"
        class="md:hidden min-h-[44px] min-w-[44px] flex items-center justify-center rounded-lg p-2 text-primary-800 transition-colors hover:text-secondary-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-sage-500/50"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open navigation menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          class="w-6 h-6"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden pt-4 pb-2 animate-slide-down">
      <div class="flex flex-col space-y-2">
        <a
          href="/"
          class="font-medium text-primary-800 hover:text-secondary-600 transition-colors py-3 min-h-[44px] flex items-center"
          >Home</a
        >
        <a
          href="/#shared-values"
          class="font-medium text-primary-800 hover:text-secondary-600 transition-colors py-3 min-h-[44px] flex items-center"
          >How we work</a
        >
        <a
          href="/#featured-project-showcase"
          class="font-medium text-primary-800 hover:text-secondary-600 transition-colors py-3 min-h-[44px] flex items-center"
          >Projects</a
        >

        <a href="/contact" class="btn-primary w-full text-center mt-2"
          >Contact Us</a
        >
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (menuToggle && mobileMenu) {
      const sync = () => {
        const open = !mobileMenu.classList.contains("hidden");
        menuToggle.setAttribute("aria-expanded", String(open));
        menuToggle.setAttribute(
          "aria-label",
          open ? "Close navigation menu" : "Open navigation menu",
        );
      };

      menuToggle.addEventListener("click", () => {
        mobileMenu.classList.toggle("hidden");
        sync();
      });
    }
  });
</script>
