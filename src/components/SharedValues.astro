---
import {
  Target,
  Shield,
  Sparkles,
  Bot,
  Rocket,
  MessageCircle,
} from "lucide-astro";

const values = [
  {
    title: "Real problems first",
    description:
      "We build for day-to-day needs: helping kids stick with practice, giving families and schools simple workflows, and taking friction out of rental operations—not pitch decks or buzzwords.",
    icon: Target,
  },
  {
    title: "Accessible by default",
    description:
      "Interfaces should work for a wide range of people and abilities. Inclusive design is part of shipping something people can actually use, not an afterthought.",
    icon: Shield,
  },
  {
    title: "Clarity over complexity",
    description:
      "Software should feel obvious. We favor plain language, thoughtful flows, and the shortest path to the outcome—whether you are a parent, a teacher, or a property owner.",
    icon: Sparkles,
  },
  {
    title: "AI with a purpose",
    description:
      "We use AI where it saves time and reduces drudgery—summaries, suggestions, and automation you can review—not as a gimmick. You stay in control of decisions that matter.",
    icon: Bot,
  },
  {
    title: "Craft and reliability",
    description:
      "We ship products we are willing to stand behind: solid engineering, performance, and care in the details, from Practice Buddy to what we are building next.",
    icon: Rocket,
  },
  {
    title: "Grounded in feedback",
    description:
      "The best ideas come from real conversations. We listen, test, and iterate with the people who use what we build so the product matches how life actually works.",
    icon: MessageCircle,
  },
];
---

<section
  id="shared-values"
  class="relative scroll-mt-[4.5rem] overflow-hidden pt-6 sm:pt-8"
>
  <img
    src="/beans.jpg"
    alt=""
    class="absolute inset-0 z-0 w-full h-full object-cover"
  />
  <div
    class="absolute inset-0 z-10"
    style="background: linear-gradient(180deg, rgba(35, 30, 28, 0.94) 0%, rgba(50, 42, 36, 0.93) 100%);"
  />

  <div
    class="section-padding container-custom relative z-20"
  >
    <div
      class="mb-12 flex flex-col gap-6 border-b border-primary-400/20 pb-10 md:mb-14 md:flex-row md:items-end md:justify-between md:gap-10"
    >
      <div class="max-w-2xl">
        <p class="kicker-on-dark">How we work</p>
        <h2
          class="font-display mt-1 text-display-2 font-semibold text-primary-50"
        >
          What drives
          <span class="text-primary-100 not-italic">everything</span> we build
        </h2>
      </div>
     
    </div>

    <ul
      class="m-0 grid list-none grid-cols-1 gap-5 p-0 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 lg:gap-6"
    >
      {
        values.map((value) => {
          const IconComponent = value.icon;
          return (
            <li class="h-full">
              <div class="values-tile h-full rounded-xl border border-primary-200/15 bg-primary-50/90 p-6 shadow-sm transition-shadow duration-200 ease-out hover:shadow-md">
                <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-900/95 text-primary-100">
                  <IconComponent class="h-5 w-5" />
                </div>
                <h3 class="font-display text-lg font-semibold text-primary-950">
                  {value.title}
                </h3>
                <p class="mt-2 text-base leading-relaxed text-primary-800/95">
                  {value.description}
                </p>
              </div>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
