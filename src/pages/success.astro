---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import img from "../assets/logo-new.png";
---

<Layout
  title="Message Sent | Beanpot Studio"
  description="Thank you for contacting Beanpot Studio. We have received your message and will get back to you shortly."
>
  <section class="my-12" aria-labelledby="success-title">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-[1.5fr,1fr] gap-8 items-start">
        <div class="order-1">
          <h1
            id="success-title"
            class="font-display text-display-1 font-semibold text-primary-900 pb-5 w-full sm:w-2/3"
          >
            Thank you!
          </h1>
          <div class="w-full pt-5">
            <p class="max-w-prose font-sans text-xl leading-[1.625] text-primary-800 sm:text-2xl">
              Thank you for reaching out; expect to hear back soon.
            </p>
          </div>
        </div>

        <div class="order-2 flex justify-center">
          <Image
            src={img}
            alt=""
            class="w-72 h-auto hidden lg:block"
            loading="eager"
          />
        </div>


      </div>
    </div>
  </section>
</Layout>
